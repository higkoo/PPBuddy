# 数据库配置
DATABASE_PATH=./data/workmate.db

# JWT 配置
# 生产环境请修改为更复杂的密钥
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# QwenPaw API 配置
# 如果不需要 AI 功能，可以不配置（系统会使用模拟响应）
QWENPAW_BASE_URL=http://localhost:8000
QWENPAW_API_KEY=
QWENPAW_TIMEOUT=30000

# 服务配置
PORT=3000
NODE_ENV=development
